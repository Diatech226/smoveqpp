# CMS frontend (Vite)
VITE_CMS_PORT=5174
VITE_PUBLIC_APP_URL=http://127.0.0.1:5173/#home
VITE_API_BASE_URL=/api/v1

# Backend origin used by the CMS Vite proxy.
# Prefer IPv4 loopback locally to avoid ::1/IPv6 refusals.
VITE_API_ORIGIN=http://127.0.0.1:3001

# Optional override when sharing root .env with server config
API_PORT=3001
