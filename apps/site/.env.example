# Public site frontend (Vite)
VITE_PORT=5173

# API endpoint consumed by site app (can be relative when proxied)
VITE_API_BASE_URL=/api/v1

# API origin used by local Vite proxy and local development
VITE_API_ORIGIN=http://127.0.0.1:3001

# Public URL of this site deployment (used in canonical/public links when needed)
VITE_PUBLIC_SITE_URL=http://127.0.0.1:5173/#home

# Standalone CMS URL for "Espace admin" style links
VITE_CMS_APP_URL=http://127.0.0.1:5174/#cms

# Optional timeout override for API requests
VITE_REQUEST_TIMEOUT_MS=10000

# Optional feature toggles
VITE_ENABLE_CMS=true
VITE_ENABLE_REGISTRATION=true
