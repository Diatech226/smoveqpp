## Shared frontend runtime (public site + CMS)
# Both frontends MUST point to the same API origin/base.
VITE_PORT=5173
VITE_CMS_PORT=5174
VITE_API_BASE_URL=/api/v1
VITE_API_ORIGIN=http://localhost:3001
VITE_REQUEST_TIMEOUT_MS=10000
VITE_PUBLIC_SITE_URL=http://localhost:5173/#home
VITE_CMS_APP_URL=/cms/#cms

# Backend (Express)
API_PORT=3001
API_ORIGIN=http://localhost:3001
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174
SESSION_SECRET=replace-with-strong-secret-at-least-32-chars

# Auth/session persistence mode: mongo|memory|auto
# Use `auto` for local stability (falls back to memory when Mongo is unavailable).
# Force `mongo` in production.
AUTH_STORAGE_MODE=auto
SESSION_STORE_MODE=auto

# MongoDB
MONGO_URI=mongodb://localhost:27017/smoveqpp
MONGO_DB_NAME=smoveqpp

# Session + password security
SESSION_TTL_SECONDS=86400
PASSWORD_HASH_ROUNDS=12
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Initial admin seeding
SEED_ADMIN_ON_START=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
ADMIN_NAME=Platform Admin

# OAuth providers (backend verified)
ENABLE_EMAIL_PASSWORD_AUTH=true
ENABLE_GOOGLE_LOGIN=false
ENABLE_FACEBOOK_LOGIN=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/facebook/callback
OAUTH_DEFAULT_ROLE=viewer

# Registration + email
PUBLIC_REGISTRATION_ENABLED=true
CONTACT_TO_EMAIL=contact@your-domain.com
EMAIL_FROM=SMOVE <noreply@your-domain.com>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Frontend feature flags
VITE_ENABLE_CMS=true
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_EMAIL_PASSWORD_AUTH=true
VITE_ENABLE_GOOGLE_LOGIN=false
VITE_ENABLE_FACEBOOK_LOGIN=false
VITE_ENABLE_DEV_ADMIN=false

# Media persistence
CONTENT_SCHEMA_VERSION=3
MEDIA_UPLOAD_DIR=apps/api/server/data/uploads
MEDIA_PUBLIC_BASE_PATH=/uploads
MEDIA_MAX_UPLOAD_BYTES=5242880
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,application/pdf
