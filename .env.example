# Shared frontend runtime (public site + CMS)
VITE_PORT=5173
VITE_CMS_PORT=5174
VITE_API_BASE_URL=/api/v1
VITE_API_ORIGIN=http://localhost:3001
VITE_REQUEST_TIMEOUT_MS=10000
VITE_PUBLIC_SITE_URL=http://localhost:5173/#home
VITE_CMS_APP_URL=/cms/#cms

# Backend (Express)
API_PORT=3001
API_ORIGIN=http://localhost:3001
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174
SESSION_SECRET=replace-with-strong-secret-at-least-32-chars

# Auth persistence mode: auto|mongo|memory
AUTH_STORAGE_MODE=auto
SESSION_STORE_MODE=auto

# MongoDB
MONGO_URI=mongodb://localhost:27017/smoveqpp
MONGO_DB_NAME=smoveqpp

# Session + password security
SESSION_TTL_SECONDS=86400
PASSWORD_HASH_ROUNDS=12
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Initial admin seeding
SEED_ADMIN_ON_START=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
ADMIN_NAME=Platform Admin


