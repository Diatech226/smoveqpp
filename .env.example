# =========================
# Shared runtime defaults for production architecture
# Site: https://www.smovecommunication.com
# CMS:        https://smoovecms.vercel.app
# =========================

# Frontend runtime (site + cms)
VITE_PORT=5173
VITE_CMS_PORT=5174
VITE_API_URL=http://127.0.0.1:3001/api/v1
VITE_API_ORIGIN=http://127.0.0.1:3001
VITE_PUBLIC_SITE_URL=https://www.smovecommunication.com
VITE_CMS_APP_URL=https://smoovecms.vercel.app/#cms
VITE_REQUEST_TIMEOUT_MS=10000

# Backend API runtime
API_PORT=3001
API_ORIGIN=http://127.0.0.1:3001
FRONTEND_ORIGIN=https://www.smovecommunication.com
FRONTEND_ORIGINS=https://www.smovecommunication.com,https://smoovecms.vercel.app
CORS_ORIGINS=https://www.smovecommunication.com,https://smoovecms.vercel.app
ALLOW_CMS_VERCEL_PREVIEW_ORIGINS=false

# MongoDB
MONGO_URI=
MONGO_DB_NAME=smoveqpp

# Auth/session
SESSION_SECRET=replace_with_strong_secret_min_32_chars
AUTH_STORAGE_MODE=mongo
SESSION_STORE_MODE=mongo
SESSION_TTL_SECONDS=86400
PASSWORD_HASH_ROUNDS=12
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Auth providers
ENABLE_EMAIL_PASSWORD_AUTH=true
PUBLIC_REGISTRATION_ENABLED=true
ENABLE_GOOGLE_LOGIN=false
ENABLE_FACEBOOK_LOGIN=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://smoveapi-1.onrender.com/api/v1/auth/oauth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://smoveapi-1.onrender.com/api/v1/auth/oauth/facebook/callback
DEFAULT_PUBLIC_ROLE=client
OAUTH_DEFAULT_ROLE=viewer

# Admin seed
SEED_ADMIN_ON_START=true
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Platform Admin

# Email / contact / password reset
CONTACT_TO_EMAIL=
EMAIL_FROM=SMOVE <noreply@smove-three.vercel.app>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Frontend feature flags
VITE_ENABLE_CMS=true
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_EMAIL_PASSWORD_AUTH=true
VITE_ENABLE_GOOGLE_LOGIN=false
VITE_ENABLE_FACEBOOK_LOGIN=false
VITE_ENABLE_DEV_ADMIN=false

# Media
CONTENT_SCHEMA_VERSION=3
MEDIA_UPLOAD_DIR=api/server/data/uploads
MEDIA_PUBLIC_BASE_PATH=/uploads
MEDIA_MAX_UPLOAD_BYTES=5242880
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,application/pdf

# Cloudinary media source of truth
MEDIA_STORAGE_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=smove
