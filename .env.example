# =============================================
# SMOVE — Environment template (V7)
# Copier ce fichier vers .env (ou .env.local) puis ajuster les valeurs.
# =============================================

# --------------------------------------
# APP (frontend + API URLs)
# --------------------------------------
# URL publique du front Vite (utilisée par l'API pour CORS/cookies).
CLIENT_ORIGIN=http://localhost:5173
# Base URL consommée côté front pour appeler l'API Express.
VITE_API_BASE_URL=http://localhost:4000/api
# Port de l'API Express.
PORT=4000
# En production, définir NODE_ENV=production pour cookies sécurisés.
NODE_ENV=development

# --------------------------------------
# DATABASE (MongoDB)
# --------------------------------------
# URI MongoDB utilisée par l'API et le script de migration V3.
MONGO_URI=mongodb://127.0.0.1:27017/smove

# --------------------------------------
# AUTH / ADMIN
# --------------------------------------
# Secret de session Express (obligatoire hors local).
SESSION_SECRET=change-this-session-secret
# Liste d'emails admin séparés par des virgules.
ADMIN_EMAILS=admin@smove.com

# --------------------------------------
# CMS FRONTEND FLAGS
# --------------------------------------
# Active/désactive le CMS côté client.
VITE_ENABLE_CMS=true
# Active/désactive l'inscription côté client.
VITE_ENABLE_REGISTRATION=true
# Autorise un compte admin de développement côté front (uniquement en DEV).
VITE_ENABLE_DEV_ADMIN=true

# Compte admin local injecté côté client en mode dev.
VITE_DEV_ADMIN_EMAIL=admin.local@smove.test
VITE_DEV_ADMIN_PASSWORD=change-me-now
VITE_DEV_ADMIN_NAME=Dev Admin

# --------------------------------------
# OAUTH PROVIDERS (optionnel)
# --------------------------------------
# Si laissés vides, seuls les logins locaux sont disponibles.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/facebook/callback

# --------------------------------------
# API VERSIONING / FEATURE FLAGS
# --------------------------------------
APP_VERSION=v3
DEFAULT_TENANT_SLUG=default
FEATURE_MULTI_TENANT=true
FEATURE_BRAND_API_V1=true
FEATURE_V5_PERSONALIZATION=true
FEATURE_V5_GLOBAL_SEARCH=true
FEATURE_V5_LEADS=true
FEATURE_V5_JOBS=true
# Token attendu par les endpoints internes de job runner.
JOB_RUNNER_TOKEN=local-dev-job-token

# --------------------------------------
# BRAND FALLBACKS (optionnel)
# --------------------------------------
# Valeurs utilisées si aucune configuration de branding n'est stockée en base.
BRAND_COLOR_PRIMARY=#00b3e8
BRAND_COLOR_SECONDARY=#34c759
BRAND_FONT_HEADING=ABeeZee
BRAND_FONT_BODY=Abhaya Libre
