# =============================================
# SMOVE — Environment template (V7)
# Copy to .env for local development.
# =============================================

# --- Core database (requested contract for future Prisma/Mongo usage) ---
# Currently not consumed by this Vite/Express codebase, reserved for next backend iterations.
DATABASE_URL=
DIRECT_DATABASE_URL=

# --- Auth/JWT contract (future API convergence) ---
# Reserved for token-based auth flows in future releases.
JWT_SECRET=

# --- Application URLs ---
# Public app URL for links/callbacks.
APP_URL=http://localhost:5173
# Public site URL exposed to client runtime.
NEXT_PUBLIC_SITE_URL=http://localhost:5173
# Current frontend API base used by AuthContext (active in this repo).
VITE_API_BASE_URL=http://localhost:4000/api

# --- Dev feature toggles (active in frontend) ---
VITE_ENABLE_CMS=true
VITE_ENABLE_REGISTRATION=true

# --- Admin bootstrap contract (future server bootstrap command) ---
ADMIN_BOOTSTRAP_EMAIL=admin@smove.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-now
ADMIN_BOOTSTRAP_ALLOW_PROD=false

# --- Media system ---
# Storage mode used by media roadmap. Current build is localStorage-first.
MEDIA_STORAGE=local
# Base URL for resolving publicly accessible media URLs.
MEDIA_PUBLIC_BASE_URL=http://localhost:5173/uploads
# Upload safeguards (bytes / files per batch) for future server-side uploads.
MEDIA_MAX_BYTES=10485760
MEDIA_MAX_FILES=10

# --- S3 compatible storage (optional, future) ---
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# --- Hero video (client-facing optional overrides) ---
NEXT_PUBLIC_HERO_VIDEO_URL=
NEXT_PUBLIC_HERO_VIDEO_POSTER=
NEXT_PUBLIC_HERO_DELAY_MS=0

# --- Current Express API runtime (ACTIVE) ---
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/smove
SESSION_SECRET=change-this-session-secret
ADMIN_EMAILS=admin@smove.com

# --- OAuth providers (optional, ACTIVE if configured) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/facebook/callback

# --- Feature flags used by server/index.js ---
FEATURE_MULTI_TENANT=true
FEATURE_BRAND_API_V1=true
FEATURE_V5_PERSONALIZATION=true
FEATURE_V5_GLOBAL_SEARCH=true
FEATURE_V5_LEADS=true
FEATURE_V5_JOBS=true
JOB_RUNNER_TOKEN=local-dev-job-token
DEFAULT_TENANT_SLUG=default
APP_VERSION=v3
