# Frontend (Vite)
VITE_PORT=5173
CLIENT_PORT=5173
VITE_API_BASE_URL=/api/v1
VITE_API_ORIGIN=http://127.0.0.1:3001
VITE_REQUEST_TIMEOUT_MS=10000
VITE_CMS_APP_URL=http://127.0.0.1:5174
VITE_CMS_PORT=5174
VITE_PUBLIC_SITE_URL=http://127.0.0.1:5173/#home
VITE_PUBLIC_APP_URL=http://127.0.0.1:5173/#home

# Backend (Express auth API)
API_PORT=3001
FRONTEND_ORIGIN=http://127.0.0.1:5173
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174
# Optional explicit CMS/public app origins (OAuth safe redirect allow-list)
CMS_ORIGIN=http://127.0.0.1:5174
CMS_FRONTEND_ORIGIN=http://127.0.0.1:5174
API_ORIGIN=http://127.0.0.1:3001
SESSION_SECRET=replace-with-strong-secret-at-least-32-chars

# Auth persistence mode: auto|mongo|memory
# - mongo: fail startup if MongoDB is unavailable
# - auto: use MongoDB when configured, otherwise dev-only memory fallback
# - memory: explicit non-persistent fallback
AUTH_STORAGE_MODE=auto

# Session store mode: auto|mongo|memory
# - production requires mongo
SESSION_STORE_MODE=auto

# MongoDB
MONGO_URI=mongodb://localhost:27017/smoveqpp
MONGO_DB_NAME=smoveqpp

# Session + password security
SESSION_TTL_SECONDS=86400
PASSWORD_HASH_ROUNDS=12
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Initial admin seeding (enabled by default for local bootstrap)
SEED_ADMIN_ON_START=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
ADMIN_NAME=Platform Admin

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://127.0.0.1:3001/api/v1/auth/oauth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://127.0.0.1:3001/api/v1/auth/oauth/facebook/callback
OAUTH_DEFAULT_ROLE=viewer

# Public registration (keep backend/frontend aligned)
PUBLIC_REGISTRATION_ENABLED=true

# Transactional email delivery
CONTACT_TO_EMAIL=contact@your-domain.com
EMAIL_FROM=SMOVE <noreply@your-domain.com>
RESEND_API_KEY=
# SMTP fallback (optional when RESEND_API_KEY is set)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional frontend feature flags
VITE_ENABLE_CMS=true
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_DEV_ADMIN=false

# Content + media persistence hardening
CONTENT_SCHEMA_VERSION=2
MEDIA_UPLOAD_DIR=apps/api/server/data/uploads
MEDIA_PUBLIC_BASE_PATH=/uploads
MEDIA_MAX_UPLOAD_BYTES=5242880
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,application/pdf
