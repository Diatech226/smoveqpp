{
  "name": "smove-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:all": "node scripts/dev-all.js",
    "dev:site": "vite --config apps/site/vite.config.ts",
    "dev:cms": "vite --config apps/cms/vite.config.ts",
    "dev:api": "node apps/api/server/index.js",
    "build": "npm run build:site && npm run build:cms && npm run build:api",
    "build:site": "vite build --config apps/site/vite.config.ts",
    "build:cms": "vite build --config apps/cms/vite.config.ts",
    "build:api": "node -e \"console.log('API build step not required for Node runtime');\"",
    "preview:site": "vite preview --config apps/site/vite.config.ts",
    "preview:cms": "vite preview --config apps/cms/vite.config.ts",
    "start:api": "node apps/api/server/index.js",
    "lint": "node scripts/lint.js",
    "typecheck": "node scripts/typecheck.js",
    "test": "npm run test:site && npm run test:api",
    "test:site": "vitest run apps/site/src/**/*.test.ts",
    "test:api": "node --test apps/api/server/tests/*.test.js",
    "test:e2e:smoke": "node scripts/test-auth-smoke.js",
    "ops:backup": "node scripts/backup-content.js",
    "ops:restore": "node scripts/restore-content.js",
    "ops:verify-integrity": "node scripts/verify-content-integrity.js"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "*",
    "cmdk": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.487.0",
    "motion": "12.33.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "sonner": "^2.0.3",
    "tailwind-merge": "*",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
