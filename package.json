{
  "name": "smove-monorepo",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/site",
    "apps/cms",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:all": "node scripts/dev-all.js",
    "dev:site": "npm run dev -w @smove/site",
    "dev:cms": "npm run dev -w @smove/cms",
    "dev:api": "npm run dev -w @smove/api",
    "build": "npm run build:site && npm run build:cms && npm run build:api",
    "build:site": "npm run build -w @smove/site",
    "build:cms": "npm run build -w @smove/cms",
    "build:api": "npm run build -w @smove/api",
    "preview:site": "npm run preview -w @smove/site",
    "preview:cms": "npm run preview -w @smove/cms",
    "start:api": "npm run start -w @smove/api",
    "lint": "node scripts/lint.js",
    "typecheck": "node scripts/typecheck.js",
    "test": "npm run test:site && npm run test:api",
    "test:site": "npm run test -w @smove/site",
    "test:api": "npm run test -w @smove/api",
    "test:e2e:smoke": "node scripts/test-auth-smoke.js",
    "ops:backup": "node scripts/backup-content.js",
    "ops:restore": "node scripts/restore-content.js",
    "ops:verify-integrity": "node scripts/verify-content-integrity.js"
  }
}
